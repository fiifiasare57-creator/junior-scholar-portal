<!DOCTYPE html>
<html>
<head>
    <title>Create Junior Scholar Icon</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 20px;
            background: #f5f5f5;
        }
        canvas {
            margin: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            border-radius: 20px;
        }
        button {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            margin: 10px;
        }
        button:hover {
            background: #764ba2;
        }
    </style>
</head>
<body>
    <h2>The Junior Scholar Portal Icon</h2>
    <canvas id="iconCanvas" width="192" height="192"></canvas>
    <br>
    <button onclick="downloadIcon()">Download icon-192.png</button>
    <p>Click the button to download the app icon</p>

    <script>
        const canvas = document.getElementById('iconCanvas');
        const ctx = canvas.getContext('2d');
        
        // Draw icon
        function drawIcon() {
            // Background gradient
            const gradient = ctx.createLinearGradient(0, 0, 192, 192);
            gradient.addColorStop(0, '#667eea');
            gradient.addColorStop(1, '#764ba2');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, 192, 192);
            
            // Rounded corners effect
            ctx.globalCompositeOperation = 'destination-in';
            ctx.beginPath();
            ctx.arc(96, 96, 96, 0, Math.PI * 2);
            ctx.fill();
            ctx.globalCompositeOperation = 'source-over';
            
            // Re-draw gradient inside circle
            ctx.fillStyle = gradient;
            ctx.beginPath();
            ctx.arc(96, 96, 96, 0, Math.PI * 2);
            ctx.fill();
            
            // Draw book emoji
            ctx.font = '96px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", Arial';
            ctx.fillStyle = 'white';
            ctx.fillText('📚', 48, 140);
        }
        
        drawIcon();
        
        function downloadIcon() {
            const link = document.createElement('a');
            link.download = 'icon-192.png';
            link.href = canvas.toDataURL();
            link.click();
        }
    </script>
</body>
</html>
